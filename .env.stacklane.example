# Stacklane env file.
# Copy this file to `.env.stacklane` and use the file location to define scope:
#
# - <stack-home>/.env.stacklane  => stack-owned shared defaults
# - <project>/.env.stacklane     => project-local user overrides
#
# Machine-generated env files are written to
# <stack-home>/.stacklane-state/envfiles/*.env and should not be edited.
#
# Selecting which installed Stacklane copy a project uses remains a machine-level
# concern for now: keep using STACK_HOME or --stack-home until a dedicated
# multi-step project installer exists.
#
# Variables defined here apply according to location. A project-root
# `.env.stacklane` overrides the same key from <stack-home>/.env.stacklane.
# CLI flags still win over both.
#
# If a project has no `.env.stacklane` yet, `stacklane up` and `stacklane attach`
# assume defaults for that first run and write a starter project file.
#
# NOTE (FR-016): STACKLANE_POST_UP_COMMAND is intentionally NOT honored
# from the stack-home copy. Post-up hooks are honored only when this file lives
# in a project root so that one project cannot smuggle commands into another.

# Explicit stack kind.
# `20i` is the only implemented stack today.
# Future follow-on stacks may include lighter presets such as `laravel` or `node`,
# but those names are not supported by the current runtime yet.
# The current `20i` stack resolves to `docker-compose.20i.yml`.
STACKLANE_STACK=20i

# First-stage hostname policy
# Use .test (default) for zero-friction HTTP-only local dev.
# Use .dev for HSTS-preloaded TLS — requires mkcert (brew install mkcert && mkcert -install)
SITE_SUFFIX=test
# SITE_SUFFIX=dev

# Runtime defaults
PHP_VERSION=8.5
MYSQL_VERSION=10.6
MYSQL_ROOT_PASSWORD=root

# Local DNS defaults
# LOCAL_DNS_PROVIDER=dnsmasq
# LOCAL_DNS_IP=127.0.0.1
# LOCAL_DNS_PORT=53535
# LOCAL_DNS_SUFFIX=test

# Per-project published service ports (defaults for every project)
# MYSQL_PORT=3306
# PMA_PORT=8081

# Optional stack-wide defaults for project config resolution.
# Project-root .env.stacklane files and CLI flags take precedence.
# DOCROOT=public_html
# MYSQL_DATABASE=my_project
# MYSQL_USER=my_project
# MYSQL_PASSWORD=devpass

# Project-only examples
# These are intended for <project>/.env.stacklane, not the stack-home copy.
# STACKLANE_STACK=20i
# SITE_NAME=my-site
# SITE_HOSTNAME=exact.test
# DOCROOT=public_html
# STACKLANE_POST_UP_COMMAND=php artisan migrate --force --no-interaction
